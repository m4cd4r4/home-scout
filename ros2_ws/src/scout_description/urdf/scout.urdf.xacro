<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="home_scout">

  <!-- ============================================ -->
  <!-- Properties                                    -->
  <!-- ============================================ -->
  <xacro:property name="base_width" value="0.24"/>
  <xacro:property name="base_length" value="0.30"/>
  <xacro:property name="base_height" value="0.10"/>
  <xacro:property name="wheel_radius" value="0.033"/>
  <xacro:property name="wheel_width" value="0.026"/>
  <xacro:property name="wheel_offset_x" value="0.10"/>
  <xacro:property name="wheel_offset_y" value="${base_width / 2 + wheel_width / 2}"/>
  <xacro:property name="caster_radius" value="0.015"/>
  <xacro:property name="camera_height" value="0.18"/>
  <xacro:property name="lidar_height" value="0.14"/>

  <!-- ============================================ -->
  <!-- Materials                                     -->
  <!-- ============================================ -->
  <material name="dark_grey">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="light_grey">
    <color rgba="0.7 0.7 0.7 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.1 0.3 0.8 1.0"/>
  </material>

  <!-- ============================================ -->
  <!-- Wheel macro                                   -->
  <!-- ============================================ -->
  <xacro:macro name="wheel" params="prefix x_offset y_offset">
    <link name="${prefix}_wheel_link">
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="dark_grey"/>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.1"/>
        <inertia ixx="0.00003" ixy="0" ixz="0" iyy="0.00003" iyz="0" izz="0.00005"/>
      </inertial>
    </link>
    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel_link"/>
      <origin xyz="${x_offset} ${y_offset} 0" rpy="${-pi/2} 0 0"/>
      <axis xyz="0 0 1"/>
    </joint>
  </xacro:macro>

  <!-- ============================================ -->
  <!-- Base link                                     -->
  <!-- ============================================ -->
  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <origin xyz="0 0 ${base_height / 2}" rpy="0 0 0"/>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <origin xyz="0 0 ${base_height / 2}" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="2.5"/>
      <origin xyz="0 0 ${base_height / 2}"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.02"/>
    </inertial>
  </link>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <!-- ============================================ -->
  <!-- Drive wheels (4WD differential)               -->
  <!-- ============================================ -->
  <xacro:wheel prefix="front_left"  x_offset="${wheel_offset_x}"  y_offset="${wheel_offset_y}"/>
  <xacro:wheel prefix="front_right" x_offset="${wheel_offset_x}"  y_offset="${-wheel_offset_y}"/>
  <xacro:wheel prefix="rear_left"   x_offset="${-wheel_offset_x}" y_offset="${wheel_offset_y}"/>
  <xacro:wheel prefix="rear_right"  x_offset="${-wheel_offset_x}" y_offset="${-wheel_offset_y}"/>

  <!-- ============================================ -->
  <!-- Camera link (front-facing MIPI-CSI)           -->
  <!-- ============================================ -->
  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.02 0.04 0.02"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.02 0.04 0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="${base_length / 2} 0 ${camera_height}" rpy="0 0 0"/>
  </joint>

  <link name="camera_optical_frame"/>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_frame"/>
    <!-- Rotate from ROS convention (x-forward) to optical convention (z-forward) -->
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

  <!-- ============================================ -->
  <!-- LiDAR link (LD19 on top of chassis)           -->
  <!-- ============================================ -->
  <link name="lidar_link">
    <visual>
      <geometry>
        <cylinder radius="0.035" length="0.03"/>
      </geometry>
      <material name="light_grey"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.035" length="0.03"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 ${lidar_height}" rpy="0 0 0"/>
  </joint>

  <!-- ============================================ -->
  <!-- IMU link (BMI270 on main board)               -->
  <!-- ============================================ -->
  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 ${base_height / 2}" rpy="0 0 0"/>
  </joint>

</robot>
